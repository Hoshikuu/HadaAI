import sounddevice as sd
import soundfile as sf

FS = 16000      # 16 kHz
DUR = 5         # segundos
CHANNELS = 1    # mono

print("Grabando... habla ahora")
audio = sd.rec(int(DUR * FS), samplerate=FS, channels=CHANNELS, dtype="float32")
sd.wait()
sf.write("test.wav", audio, FS)
print("Guardado: test.wav")
